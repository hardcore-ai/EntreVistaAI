# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=...
TELEGRAM_WEBHOOK_URL=https://your-domain.com/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=your-random-secret

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://entrevista:secret@postgres:5432/entrevista_db
DATABASE_SYNC_URL=postgresql://entrevista:secret@postgres:5432/entrevista_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Auth ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-32-random-chars
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ─── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
API_BASE_URL=http://backend:8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ─── Retention ────────────────────────────────────────────────────────────────
DEFAULT_RETENTION_DAYS=90
REENGAGEMENT_FIRST_HOURS=24
REENGAGEMENT_SECOND_HOURS=48
REENGAGEMENT_FINAL_HOURS=72
